# ============================================
# 青年驿站项目 - 环境变量样例
# 复制为 .env 后填入你自己的 Key（.env 不会被提交）
# ============================================

# Flask 密钥（生产请用强随机字符串）
SECRET_KEY=please-change-me-to-a-random-long-string

# 默认管理员（首次启动会自动创建）
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin123

# ===== 高德地图 =====
# 注册：https://lbs.amap.com/  → 控制台 → 应用管理
AMAP_JS_KEY=
AMAP_JS_SECRET=
AMAP_WEB_KEY=

# ===== AI 服务（OpenAI 兼容协议）=====
# 推荐 DeepSeek（极便宜）：https://platform.deepseek.com
# 也支持 智谱GLM / 腾讯混元 / 通义千问 / 豆包 / GPT / Claude / Gemini
AI_API_KEY=sk-your-api-key
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
